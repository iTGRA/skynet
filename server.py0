from fastmcp import FastMCP

mcp = FastMCP("hello-world")

@mcp.tool()
def hello(name: str = "world") -> str:
    """Поприветствовать пользователя"""
    return f"Hello, {name}!"

@mcp.tool()
def ping() -> str:
    """Простой пинг"""
    return "pong"

if __name__ == "__main__":
    mcp.run(
        transport="sse",      # ← лучше "http", а не "sse"
        host="127.0.0.1",        # обязательно, чтобы был доступен снаружи
        port=8000
    )
